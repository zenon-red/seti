{
  "name": "@zenon-red/seti",
  "version": "1.0.0",
  "description": "Web search CLI and MCP server powered by SearXNG with optional API fallback providers and content enrichment.",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "seti": "dist/src/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "bun src/index.ts",
    "setup": "bun src/setup/index.ts",
    "lint": "oxlint src/",
    "lint:fix": "oxlint src/ --fix",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc",
    "test": "bun test dist/**/*.test.js"
  },
  "keywords": [
    "mcp",
    "search",
    "web-search",
    "ai",
    "agents",
    "tavily",
    "exa",
    "jina",
    "brave",
    "firecrawl",
    "provider-routing",
    "free-tier"
  ],
  "author": "ZŌE",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@toon-format/toon": "^2.1.0",
    "axios": "^1.13.5",
    "c12": "^3.0.4",
    "consola": "^3.4.2",
    "kolorist": "^1.8.0",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zenon-red/seti.git"
  },
  "bugs": {
    "url": "https://github.com/zenon-red/seti/issues"
  },
  "homepage": "https://github.com/zenon-red/seti"
}
