# SETI default profile: prioritize local SearXNG
SETI_PROVIDER_ROUTING_STRATEGY=priority
SETI_SEARXNG_BASE_URL=http://127.0.0.1:8888

# Keep provider support in code, but disable non-SearXNG providers for this local profile
SETI_TAVILY_ENABLED=false
SETI_EXA_ENABLED=false
SETI_JINA_ENABLED=false
SETI_BRAVE_ENABLED=false
SETI_GOOGLE_ENABLED=false
SETI_FIRECRAWL_ENABLED=false
SETI_SERPAPI_ENABLED=false
SETI_DUCKDUCKGO_ENABLED=false

# Runtime defaults
SETI_LOG_LEVEL=info
SETI_CACHE_ENABLED=true
SETI_CACHE_TTL=300
SETI_DEFAULT_RESULTS=20
SETI_MAX_RESULTS=100
SETI_TIMEOUT_MS=30000

# Jina AI Reader API key (optional, for higher rate limits on content enrichment)
# Get your API key at: https://jina.ai/reader
# Without a key: 20 requests/minute (free)
# With a key: Higher rate limits based on your plan
# JINA_READER_API_KEY=

# Optional API keys if you re-enable providers later
# TAVILY_API_KEY=
# EXA_API_KEY=
# JINA_API_KEY=
# BRAVE_API_KEY=
# GOOGLE_API_KEY=
# GOOGLE_CX=
# FIRECRAWL_API_KEY=
# SERPAPI_API_KEY=
